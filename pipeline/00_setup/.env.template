# Sekrety pipeline — skopiuj jako .env (gitignored) i wypełnij
# UWAGA: nigdy nie commit'uj .env!

# DiffBot API (https://app.diffbot.com)
DIFFBOT_TOKEN=

# Hugging Face (https://huggingface.co/settings/tokens)
# Wymaga zaakceptowania licencji meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=

# Modal cloud (po `modal token new` zapisane są w ~/.modal.toml)
# Te wpisy potrzebne tylko jeśli używasz Modal w skryptach bez interaktywnego CLI:
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Weights & Biases (opcjonalnie, do trackingu sweep'ów)
WANDB_TOKEN=
WANDB_PROJECT=umcs-disinfo-detection

# Ograniczenia kosztowe (twarde limity, sprawdzane w skryptach)
MODAL_BUDGET_USD_HARD_LIMIT=200
DIFFBOT_BUDGET_CALLS_HARD_LIMIT=10000
